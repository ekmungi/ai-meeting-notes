# AssemblyAI API key (required for cloud transcription)
ASSEMBLYAI_API_KEY=your_api_key_here

# Output directory for markdown files (default: current directory)
# OUTPUT_DIR=./notes

# Transcription engine: cloud, local, auto (default: auto)
# ENGINE=auto

# Endpointing: how aggressively to split at pauses
# Options: aggressive, balanced, conservative, very_conservative
# Default: conservative (best for meetings with natural pauses)
# ENDPOINTING=conservative

# Timestamp mode: none, local_time, elapsed (default: elapsed)
# TIMESTAMP_MODE=elapsed

# Local engine model size (default: small.en)
# Options: tiny.en, base.en, distil-small.en, small.en, distil-large-v3, medium.en
# LOCAL_MODEL_SIZE=small.en

# Local engine compute type (default: int8)
# LOCAL_COMPUTE_TYPE=int8

# Local engine CPU thread count (default: auto-detect as cpu_count // 2)
# Set to 0 to auto-detect, or specify a number (e.g. 2, 4, 8)
# LOCAL_CPU_THREADS=0

# Local engine audio accumulation window (default: 10 seconds)
# Whisper's encoder processes 30s internally; 10s halves inference calls vs 5s
# with only ~20% latency increase per call
# LOCAL_CHUNK_SECONDS=10

# Audio device indices (use --list-devices to find them)
# MIC_DEVICE_INDEX=
# SYSTEM_AUDIO_DEVICE_INDEX=
