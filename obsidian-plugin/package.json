{
  "name": "obsidian-ai-meeting-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Obsidian plugin for AI Meeting Notes",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --platform=node --target=es2020",
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --platform=node --target=es2020 --watch"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "obsidian": "latest"
  }
}
