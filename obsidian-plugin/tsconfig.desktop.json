{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist-desktop",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/shared/**/*", "src/desktop/**/*"]
}
